# Application Settings
APP_NAME=Employee Metrics Dashboard
APP_VERSION=0.1.0
DEBUG=True
ENVIRONMENT=development

# Server Settings
HOST=0.0.0.0
PORT=8000

# CORS Settings
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# JWT Settings
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Data Paths (resolved from the TeamSight installation root)
RESOURCES_CSV_PATH=config/Resources.csv
ROLES_CSV_PATH=config/Roles.csv
KPI_DATA_PATH=output/
CONFIG_PATH=config/
DATA_PATH=data/

# Refresh Settings
AUTO_REFRESH_ENABLED=True
HOURLY_REFRESH_KPIS=k3,k12,k13
DAILY_REFRESH_TIME=02:00

# ROG Thresholds (default)
ROG_GREEN_MIN=0.62
ROG_ORANGE_MIN=0.40

# Data Retention
DATA_RETENTION_MONTHS=15

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/dashboard.log
